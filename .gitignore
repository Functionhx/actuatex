# Generated simulator files
*.usd
*.usda
*.usdc
compiled_*.mjcf

# Runtime-critical TinyMal capsule asset audited for the Isaac Sim 6 migration.
# Keep the broad generated-USD rule above; only this pinned, hashed package is source data.
!robots/tinymal/usd/capsule_compat/*.usd
!robots/tinymal/usd/capsule_compat/configuration/*.usd

# Open visual-only sensor shells are source assets, not generated stage dumps.
!robots/sensors/mid360/usd/*.usda

# Archives and local release packages
*.zip
*.tar
*.tar.gz
*.tgz

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp
