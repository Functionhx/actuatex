<?xml version="1.0" encoding="utf-8"?>
<robot name="actuatex_cartpole_2">
  <material name="graphite"><color rgba="0.075 0.085 0.10 1"/></material>
  <material name="orange"><color rgba="1.0 0.30 0.04 1"/></material>
  <material name="metal"><color rgba="0.48 0.53 0.58 1"/></material>
  <link name="rail">
    <inertial>
      <origin xyz="0 0 -0.020000" rpy="0 0 0"/>
      <mass value="1.00000000"/>
      <inertia ixx="0.0009666667" ixy="0" ixz="0" iyy="2.2534666667" iyz="0" izz="2.2541666667"/>
    </inertial>
    <visual><origin xyz="0 0 -0.02"/><geometry><box size="5.2 0.10 0.04"/></geometry><material name="metal"/></visual>
    <collision><origin xyz="0 0 -0.02"/><geometry><box size="5.2 0.10 0.04"/></geometry></collision>
  </link>
  <link name="cart">
    <inertial>
      <origin xyz="0 0 0.000000" rpy="0 0 0"/>
      <mass value="1.00000000"/>
      <inertia ixx="0.0069333333" ixy="0" ixz="0" iyy="0.0096333333" iyz="0" izz="0.0123000000"/>
    </inertial>
    <visual><geometry><box size="0.30 0.24 0.16"/></geometry><material name="graphite"/></visual>
    <collision><geometry><box size="0.30 0.24 0.16"/></geometry></collision>
  </link>
  <joint name="cart_slide" type="prismatic">
    <parent link="rail"/><child link="cart"/>
    <origin xyz="0 0 -0.16" rpy="0 0 0"/><axis xyz="1 0 0"/>
    <limit lower="-2.4" upper="2.4" effort="20" velocity="8"/>
    <dynamics damping="0.05" friction="0"/>
  </joint>
  <link name="pole_1">
    <inertial>
      <origin xyz="0 0 -0.300000" rpy="0 0 0"/>
      <mass value="0.20000000"/>
      <inertia ixx="0.0060266667" ixy="0" ixz="0" iyy="0.0060266667" iyz="0" izz="0.0000533333"/>
    </inertial>
    <visual><origin xyz="0 0 -0.300"/><geometry><box size="0.040 0.040 0.600"/></geometry><material name="orange"/></visual>
    <collision><origin xyz="0 0 -0.300"/><geometry><box size="0.040 0.040 0.600"/></geometry></collision>
  </link>
  <joint name="pole_1_hinge" type="continuous">
    <parent link="cart"/><child link="pole_1"/>
    <origin xyz="0 0 -0.080" rpy="0 0 0"/><axis xyz="0 -1 0"/>
    <limit effort="0" velocity="30"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>
  <link name="pole_2">
    <inertial>
      <origin xyz="0 0 -0.300000" rpy="0 0 0"/>
      <mass value="0.20000000"/>
      <inertia ixx="0.0060266667" ixy="0" ixz="0" iyy="0.0060266667" iyz="0" izz="0.0000533333"/>
    </inertial>
    <visual><origin xyz="0 0 -0.300"/><geometry><box size="0.040 0.040 0.600"/></geometry><material name="metal"/></visual>
    <collision><origin xyz="0 0 -0.300"/><geometry><box size="0.040 0.040 0.600"/></geometry></collision>
  </link>
  <joint name="pole_2_hinge" type="continuous">
    <parent link="pole_1"/><child link="pole_2"/>
    <origin xyz="0 0 -0.600" rpy="0 0 0"/><axis xyz="0 -1 0"/>
    <limit effort="0" velocity="30"/>
    <dynamics damping="0.002" friction="0"/>
  </joint>
</robot>
